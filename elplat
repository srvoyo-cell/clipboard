@torch.inference_mode()
def recognize_image(image: Image.Image) -> str:
    if state.processor is None or state.model is None:
        raise RuntimeError("Model is not loaded")

    image = image.convert("RGB")

    pixel_values = state.processor(
        images=image,
        return_tensors="pt",
    ).pixel_values.to(state.device)

    generated_ids = state.model.generate(
        pixel_values,
        num_beams=4,
        max_length=64,
    )

    text = state.processor.batch_decode(
        generated_ids,
        skip_special_tokens=True,
    )[0]

    return clean_prediction(text)
