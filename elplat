version: "3.8"

services:
  postgres:
    image: postgres:15
    container_name: mlflow-postgres
    environment:
      POSTGRES_USER: mlflow
      POSTGRES_PASSWORD: mlflow
      POSTGRES_DB: mlflow
    volumes:
      - ./postgres-data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    restart: unless-stopped

  minio:
    image: minio/minio:latest
    container_name: mlflow-minio
    environment:
      MINIO_ROOT_USER: minio
      MINIO_ROOT_PASSWORD: minio123
    command: server /data --console-address ":9001"
    volumes:
      - ./minio-data:/data
    ports:
      - "9000:9000"   # S3 API
      - "9001:9001"   # Web UI
    restart: unless-stopped

  create-bucket:
    image: minio/mc:latest
    container_name: mlflow-create-bucket
    depends_on:
      - minio
    entrypoint: >
      /bin/sh -c "
      sleep 5;
      mc alias set local http://minio:9000 minio minio123;
      mc mb -p local/mlflow || true;
      mc ls local;
      exit 0;
      "

  mlflow:
    image: ghcr.io/mlflow/mlflow:latest
    container_name: mlflow-server
    depends_on:
      - postgres
      - minio
      - create-bucket
    environment:
      AWS_ACCESS_KEY_ID: minio
      AWS_SECRET_ACCESS_KEY: minio123
      MLFLOW_S3_ENDPOINT_URL: http://minio:9000
      MLFLOW_S3_IGNORE_TLS: "true"
    command: >
      /bin/sh -c "
      pip install psycopg2-binary boto3 &&
      mlflow server
      --backend-store-uri postgresql://mlflow:mlflow@postgres:5432/mlflow
      --artifacts-destination s3://mlflow
      --host 0.0.0.0
      --port 5000
      "
    ports:
      - "100:5000"
    restart: unless-stopped


import tempfile
from pathlib import Path

from fastapi import FastAPI, UploadFile, File, HTTPException
from openai import OpenAI
from pydub import AudioSegment


app = FastAPI()
client = OpenAI()


def split_stereo_to_mono(input_path: Path, output_dir: Path) -> tuple[Path, Path]:
    audio = AudioSegment.from_file(input_path)

    if audio.channels != 2:
        raise ValueError(f"Expected stereo audio with 2 channels, got {audio.channels}")

    left_channel, right_channel = audio.split_to_mono()

    left_path = output_dir / "speaker_00.wav"
    right_path = output_dir / "speaker_01.wav"

    # Важно: длина каналов сохраняется одинаковой.
    # Поэтому timestamp'ы потом можно объединять по общей временной шкале.
    left_channel.export(left_path, format="wav")
    right_channel.export(right_path, format="wav")

    return left_path, right_path


def transcribe_with_segments(audio_path: Path, speaker: str) -> list[dict]:
    with open(audio_path, "rb") as audio_file:
        transcription = client.audio.transcriptions.create(
            model="whisper-1",
            file=audio_file,
            response_format="verbose_json",
            timestamp_granularities=["segment"],
            language="ru",
        )

    segments = []

    for segment in transcription.segments:
        text = segment.text.strip()

        if not text:
            continue

        segments.append(
            {
                "speaker": speaker,
                "start": float(segment.start),
                "end": float(segment.end),
                "text": text,
            }
        )

    return segments


def merge_nearby_segments(dialog: list[dict], max_gap: float = 1.0) -> list[dict]:
    """
    Склеивает соседние реплики одного и того же спикера,
    если между ними маленькая пауза.
    """
    if not dialog:
        return []

    merged = [dialog[0]]

    for item in dialog[1:]:
        prev = merged[-1]

        same_speaker = item["speaker"] == prev["speaker"]
        small_gap = item["start"] - prev["end"] <= max_gap

        if same_speaker and small_gap:
            prev["end"] = item["end"]
            prev["text"] = prev["text"] + " " + item["text"]
        else:
            merged.append(item)

    return merged


@app.post("/transcribe-dialog")
async def transcribe_dialog(file: UploadFile = File(...)):
    try:
        suffix = Path(file.filename or "audio.mp3").suffix or ".mp3"

        with tempfile.TemporaryDirectory() as tmp:
            tmp_dir = Path(tmp)

            input_path = tmp_dir / f"input{suffix}"
            input_path.write_bytes(await file.read())

            left_path, right_path = split_stereo_to_mono(input_path, tmp_dir)

            speaker_00_segments = transcribe_with_segments(
                audio_path=left_path,
                speaker="speaker_00",
            )

            speaker_01_segments = transcribe_with_segments(
                audio_path=right_path,
                speaker="speaker_01",
            )

            dialog = speaker_00_segments + speaker_01_segments

            # Главное место: сортируем реплики двух каналов по времени
            dialog.sort(key=lambda x: x["start"])

            # Опционально склеиваем близкие куски одного спикера
            dialog = merge_nearby_segments(dialog, max_gap=1.0)

            return {
                "dialog": dialog,
                "text": "\n".join(
                    f'{item["speaker"]}: {item["text"]}'
                    for item in dialog
                ),
            }

    except Exception as e:
        raise HTTPException(
            status_code=500,
            detail=f"Dialog transcription failed: {str(e)}",
        )

